# Personal Career Mentor RAG - Environment Configuration
# Copy this file to a new file named '.env' and fill in your keys.

# Google Gemini API Key (Required if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Required if using OpenAI provider)
OPENAI_API_KEY=your_openai_api_key_here
